@using DigitalLearningSolutions.Web.ViewModels.SuperAdmin.Delegates;
@model ConfirmationViewModel;
@{
    ViewData["Title"] = "Inactivate Delegate";
}
@if (Model.Error)
{
    <vc:error-summary order-of-property-names="@(new string[] { "IsChecked" })" />
}
@section NavBreadcrumbs {
    <nav class="nhsuk-breadcrumb" aria-label="Breadcrumb">
        <div class="nhsuk-width-container">
            <ol class="nhsuk-breadcrumb__list">
                <li class="nhsuk-breadcrumb__list-item">
                    <a class="nhsuk-breadcrumb__link" asp-controller="Delegates" asp-action="Index" asp-route-SearchString="@Model.SearchString" asp-route-ExistingFilterString="@Model.ExistingFilterString" asp-route-page="@Model.Page">Delegates</a>
                </li>
            </ol>
        </div>
    </nav>
}
<div id="form-group">
    <form method="post" asp-action="InactivateDelegateConfirmation">
        <div>
            <h1 id="form-heading" class="nhsuk-fieldset__heading nhsuk-label--l">
                Inactivate Delegate
            </h1>
            @Html.HiddenFor(x => x.DisplayName)
            @Html.HiddenFor(x => x.DelegateId)
            @Html.HiddenFor(x => x.SearchString)
            @Html.HiddenFor(x => x.ExistingFilterString)
            @Html.HiddenFor(x => x.Page)
            <h2>User: @Model.DisplayName</h2>
            <p id="IsChecked-hint">
                <vc:single-checkbox asp-for="@nameof(Model.IsChecked)"
                                    label="I am sure that I wish to inactivate this delegate account." hint-text="This action will inactivate the delegate account. It will not inactivate any associated user accounts or admin accounts."></vc:single-checkbox>
            </p>
        </div>
        <button class="nhsuk-button nhsuk-button--danger" type="submit">
            Inactivate delegate
        </button>
    </form>
    <div class="nhsuk-link">
        <a class="nhsuk-back-link__link" asp-controller="Delegates" asp-action="Index" asp-route-SearchString="@Model.SearchString" asp-route-ExistingFilterString="@Model.ExistingFilterString" asp-route-page="@Model.Page" asp-fragment="@Model.DelegateId-name">
            Cancel
        </a>
    </div>
</div>
