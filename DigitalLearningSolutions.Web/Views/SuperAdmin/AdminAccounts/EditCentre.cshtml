@using DigitalLearningSolutions.Web.ViewModels.SuperAdmin.Administrators
@model EditCentreViewModel
@{
    var errorHasOccurred = !ViewData.ModelState.IsValid;
    ViewData["Title"] = "Change Administrator Centre";
}
@if (errorHasOccurred)
{
    <vc:error-summary order-of-property-names="@(new[] { nameof(Model.CentreId) })" />
}
<h1 class="nhsuk-heading-xl">@ViewData["Title"]</h1>
@section NavBreadcrumbs {
    <nav class="nhsuk-breadcrumb" aria-label="Breadcrumb">
        <div class="nhsuk-width-container">
            <ol class="nhsuk-breadcrumb__list">
                <li class="nhsuk-breadcrumb__list-item">
                    <a class="nhsuk-breadcrumb__link" asp-controller="AdminAccounts" asp-action="Index" asp-route-SearchString="@Model.SearchString" asp-route-ExistingFilterString="@Model.ExistingFilterString" asp-route-page="@Model.Page">Administrators</a>
                </li>
            </ol>
        </div>
    </nav>
        }
<div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-full nhsuk-heading-l nhsuk-u-font-weight-normal word-break">
        <input type="hidden" asp-for="FullName" />
        @Model.FullName - @Model.CentreName
    </div>
</div>
<div id="form-group">
    <form method="post" asp-action="EditCentre">
        <vc:select-list asp-for="CentreId"
                        label="Choose Centre"
                        value="@Model.AdminCentreId.ToString()"
                        hint-text="Choose the centre to move this admin account to"
                        required="true"
                        default-option=""
                        css-class="nhsuk-u-width-full"
                        select-list-options="@ViewBag.Centres" />


        <button class="nhsuk-button nhsuk-u-margin-top-2" type="submit" value="save">Save</button>
    </form>
</div>
<div class="nhsuk-link">
    <a class="nhsuk-back-link__link" asp-controller="AdminAccounts" asp-action="Index" asp-route-SearchString="@Model.SearchString" asp-route-ExistingFilterString="@Model.ExistingFilterString" asp-route-page="@Model.Page" asp-fragment="@Model.AdminId-name">
        Cancel
    </a>
</div>
