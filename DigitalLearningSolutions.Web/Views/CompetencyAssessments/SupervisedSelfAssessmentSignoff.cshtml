@using DigitalLearningSolutions.Web.ViewModels.CompetencyAssessments
@model SupervisedSelfAssessmentSignoffViewModel
@{
    var errorHasOccurred = !ViewData.ModelState.IsValid;
    ViewData["Title"] = "Supervised self-assessment and sign off";
}

@section NavMenuItems {
    <partial name="~/Views/Frameworks/Shared/_NavMenuItems.cshtml" />
}
@section NavBreadcrumbs {
    <nav class="nhsuk-breadcrumb" aria-label="Breadcrumb">
        <div class="nhsuk-width-container">
            <ol class="nhsuk-breadcrumb__list">
                <li class="nhsuk-breadcrumb__item"><a class="nhsuk-breadcrumb__link trigger-loader" asp-controller="Frameworks" asp-action="Index">Home</a></li>
                <li class="nhsuk-breadcrumb__item"><a class="nhsuk-breadcrumb__link trigger-loader" asp-action="ViewCompetencyAssessments" asp-route-tabname="Mine">Self-assessments</a></li>
                <li class="nhsuk-breadcrumb__item"><a class="nhsuk-breadcrumb__link trigger-loader" asp-action="ManageCompetencyAssessment" asp-route-competencyAssessmentId="@Model.CompetencyAssessmentId">Manage self-assessment</a></li>
                <li class="nhsuk-breadcrumb__item">Supervisor roles</li>
            </ol>
        </div>
    </nav>
}
<div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-full">
        @if (errorHasOccurred)
        {
            <vc:error-summary order-of-property-names="@(new[] { nameof(Model.Signoff), nameof(Model.Confirm) })" />
        }
        <form method="post">
            <fieldset class="nhsuk-fieldset" aria-describedby="signoff-error">
                <h1 class="app-page-heading">
                    <span class="nhsuk-caption-xl">
                        @Model.CompetencyAssessmentName
                        <span class="nhsuk-u-visually-hidden"> – </span>
                    </span>
                    Supervisor roles
                </h1>
                <div class="nhsuk-radios nhsuk-radios--conditional">
                    <div class="nhsuk-form-group">
                        @if (ViewData.ModelState.ContainsKey("Signoff") && ViewData.ModelState["Signoff"].Errors.Count > 0)
                        {
                            <span class="nhsuk-error-message" id="Signoff-error">
                                <span class="nhsuk-u-visually-hidden">Error:</span>
                                @ViewData.ModelState[nameof(Model.Signoff)]?.Errors.FirstOrDefault()?.ErrorMessage
                            </span>
                        }
                        <div class="nhsuk-radios">
                            <label class="nhsuk-label" for="signoff-yes">
                                Will the self-assessment be supervised?
                            </label>
                            <div class="nhsuk-radios__item">
                                <input class="nhsuk-radios__input"
                                       id="signoff-no"
                                       name="Signoff"
                                       type="radio"
                                       value="0"
                                       aria-controls="conditional-signoff-yes" aria-expanded="false"
                                       @(Model.Signoff == 0 ? "checked" : "")>
                                <label class="nhsuk-label nhsuk-radios__label" for="signoff-no">
                                    No
                                </label>
                            </div>
                            <div class="nhsuk-radios__item">
                                <input class="nhsuk-radios__input" id="signoff-yes" name="Signoff" type="radio" value="1" aria-controls="conditional-signoff-yes" aria-expanded="true" @(Model.Signoff == 1 ? "checked" : "")>
                                <label class="nhsuk-label nhsuk-radios__label" for="signoff-yes">
                                    Yes
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="nhsuk-radios__conditional" id="conditional-signoff-yes">
                        <div class="nhsuk-form-group">
                            @if (ViewData.ModelState.ContainsKey("Confirm") && ViewData.ModelState["Confirm"].Errors.Count > 0)
                            {
                                <span class="nhsuk-error-message" id="Supervised-error">
                                    <span class="nhsuk-u-visually-hidden">Error:</span>
                                    @ViewData.ModelState[nameof(Model.Confirm)]?.Errors.FirstOrDefault()?.ErrorMessage
                                </span>
                            }
                            <label class="nhsuk-label" for="confirm-yes">
                                Will supervisor or nominated supervisor confirm individual assessment results?
                            </label>

                            <div class="nhsuk-radios__item">
                                <input class="nhsuk-radios__input" id="confirm-no" name="Confirm" type="radio" value="0"
                                       @(Model.Confirm == 0 ? "checked" : "")>
                                <label class="nhsuk-label nhsuk-radios__label" for="confirm-no">
                                    No
                                </label>
                            </div>
                            <div class="nhsuk-radios__item">
                                <input class="nhsuk-radios__input" id="confirm-yes" name="Confirm" type="radio" value="1" @(Model.Confirm == 1 ? "checked" : "")>
                                <label class="nhsuk-label nhsuk-radios__label" for="confirm-yes">
                                    Yes
                                </label>
                            </div>
                        </div>
                    </div>

                </div>
            </fieldset>
            <input type="hidden" asp-for="CompetencyAssessmentId" />
            <input type="hidden" asp-for="CompetencyAssessmentName" />
            <a class="nhsuk-button nhsuk-button--secondary nhsuk-u-margin-left-3" asp-action="ManageCompetencyAssessment" asp-route-competencyAssessmentId="@Model.CompetencyAssessmentId">

                Back
            </a>
            <button class="nhsuk-button" type="submit">Next</button>
        </form>
    </div>
</div>
